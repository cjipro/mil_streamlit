# .env.minimal.example — MIL-114 Tier 1 (engine only, no external publishing)
#
# Copy to `.env` if you want to run the daily pipeline locally and inspect
# the rendered briefings in mil/publish/output/ without pushing anything to
# the public internet.
#
#   cp .env.minimal.example .env
#
# The single required value is the LLM provider key. Every other tier
# (.env.publish.example, .env.full.example) is strictly additive on top.

# === Required ===

# LLM provider key. Read by:
#   - mil/config/model_client.py — the unified Claude API wrapper used by
#     enrichment, commentary, exec alert, teacher autopsies, ask-mode
#     synthesis + verifier, intent classification, and CHR proposals.
#   - mil/harvester/enrich_sonnet.py, mil/teacher/*.py, mil/researcher/*.py,
#     mil/collect_*.py — direct Anthropic-SDK callers.
# Without this key the pipeline can still fetch + dedup raw records, but
# enrichment + inference + commentary all fail.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME

# === Optional ===

# Override the local Ollama endpoint. Default: http://127.0.0.1:11434
# Set this only if your Ollama instance binds to a non-default host/port.
# Used by enrich_sonnet.py and exec-alert synthesis when the qwen3 / refuel
# routes are selected in mil/config/model_routing.yaml. If you stay on the
# all-cloud routing (Sonnet for enrichment, Haiku for verifier, etc.), you
# can leave this unset and skip running Ollama entirely.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
