# .env.publish.example — MIL-114 Tier 2 (engine + GitHub Pages push)
#
# Copy to `.env` if you want to run the daily pipeline AND publish the
# rendered briefings to a GitHub Pages repo. This is the level the
# cjipro.com hosted reference instance currently runs on for the public
# briefing surfaces.
#
#   cp .env.publish.example .env
#
# Strictly additive on top of .env.minimal.example. If you only need the
# engine running locally with no public surfaces, use that instead.

# === Tier 1 — required for engine ===

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME

# Optional Ollama override (see .env.minimal.example for context)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# === Tier 2 — required for GitHub Pages publish ===

# Personal Access Token (or fine-grained token) with write permission to
# the Pages repo. Read by mil/publish/adapters.py GitHubPagesAdapter and
# the legacy V1/V2/V3 publishers. The adapter is selected via
# mil/config/publish_config.yaml (`adapter: github_pages`).
#
# When this is unset OR PUBLISH_REPO is unset, the adapter falls back to
# NullAdapter — the pipeline still completes, briefings render to
# mil/publish/output/, but nothing pushes to the public internet.
GITHUB_TOKEN=ghp_REPLACE_ME

# Target Pages repo. Either an org/repo slug or a full HTTPS URL. The
# legacy V1 publisher accepts both. The adapter prepends the token at
# clone time, so this value is the public-facing URL.
#   examples: cjipro/mil-briefing
#             https://github.com/cjipro/mil-briefing.git
PUBLISH_REPO=your-org/your-pages-repo
