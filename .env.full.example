# .env.full.example — MIL-114 Tier 3 (every external surface)
#
# Copy to `.env` if you are operating a production CJI instance with the
# full set of external integrations enabled: Slack heartbeat, partner PDB
# email, WorkOS auth, Cloudflare DNS / Email / Workers, GitLab read-mirror,
# YouTube harvester. This is the cjipro.com hosted reference configuration.
#
#   cp .env.full.example .env
#
# Every Tier 3 value is OPTIONAL — its absence degrades a specific surface
# but never blocks the daily pipeline. The pipeline status line in
# daily_run_log.jsonl downgrades to PARTIAL when an optional step fails;
# CLEAN means every configured surface succeeded.

# === Tier 1 — required for engine ===

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME

# Optional Ollama override (see .env.minimal.example for context)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# === Tier 2 — required for GitHub Pages publish ===

GITHUB_TOKEN=ghp_REPLACE_ME
PUBLISH_REPO=your-org/your-pages-repo

# === Tier 3 — operator heartbeat (Slack) ===

# Webhook URL for the operator-facing run heartbeat. Read by
# mil/notify/notifier.py SlackAdapter — STARTING / CRASHED / CLEAN /
# PARTIAL / FAILED pings fire from run_daily.py. Without this set, the
# notifier silently no-ops; pipeline status is then visible only in
# mil/data/daily_run_log.jsonl.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME

# === Tier 3 — partner PDB email distribution ===

# SMTP credentials for the daily Sonar PDB partner email (mil/notify/
# briefing_email.py + welcome_email.py). The cjipro.com hosted instance
# uses Gmail Send-as routed through smtp.gmail.com. SMTP_FROM defaults
# to SMTP_USER if unset.
#
# When any of HOST/USER/APP_PASSWORD is empty the briefing-email step
# silently skips with an INFO log line. The pipeline status remains
# CLEAN — partner email is non-critical.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=hello@your-domain
# SMTP_APP_PASSWORD=replace-me
# SMTP_FROM=Briefings <hello@your-domain>

# === Tier 3 — WorkOS auth ===

# WorkOS API secret. The non-secret WorkOS identifiers (organisation_id,
# client_id, jwks_url, authkit_domain) live in mil/config/workos.yaml
# and are read by mil/config/workos_loader.py + Cloudflare Workers via
# wrangler.toml [vars] blocks. The drift checker
# (mil/auth/scripts/check_workos_drift.py) verifies they agree.
# WORKOS_API_KEY=sk_test_REPLACE_ME

# === Tier 3 — Cloudflare DNS / Email Routing / Workers ===

# Cloudflare API Token with permissions for: DNS read+edit, Email Routing
# read+edit, Workers Scripts read+edit, cache purge, on the cjipro.com
# zone (or your fork's zone). Read by ops/cloudflare/cf.py — the wrapper
# CLI for in-session DNS/Email/Worker operations. The Workers themselves
# deploy via `wrangler deploy` and use a separate auth flow (wrangler
# login).
# CLOUDFLARE_API_TOKEN=replace-me

# === Tier 3 — GitLab read-mirror + Jira issue archive ===

# GitLab Personal Access Token with `api` scope. Read by:
#   - ops/gitlab_import/import_jira_to_gitlab.py — mirrors Jira tickets
#     into GitLab Issues for the dev-surface visibility / Jira-issue
#     archive contract documented in CLAUDE.md.
#   - ops/runbooks/gitlab_force_push.sh — automated unprotect/push/
#     re-protect for the rebase-non-fast-forward case.
# GITLAB_TOKEN=glpat-REPLACE_ME
# GITLAB_BASE_URL=https://gitlab.com
# GITLAB_PROJECT_ID=12345678

# === Tier 3 — YouTube source ===

# YouTube Data API v3 key. Read by mil/harvester/sources/youtube.py.
# Without it the YouTube source silently returns zero records and the
# run log notes the empty fetch. Other sources continue normally.
# YOUTUBE_API_KEY=AIza-REPLACE-ME
