mil/data/historical/*
mil/data/chronicle_evidence/*
mil/data/enriched/*
mil/data/findings/*
!mil/data/signals/.gitkeep
!mil/data/historical/.gitkeep
!mil/data/chronicle_evidence/.gitkeep
!mil/data/enriched/.gitkeep
!mil/data/findings/.gitkeep

